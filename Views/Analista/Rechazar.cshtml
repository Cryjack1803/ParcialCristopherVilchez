@model RechazoSolicitudViewModel

@{
    ViewData["Title"] = "Rechazar solicitud";
    var solicitud = ViewBag.Solicitud as SolicitudCredito;
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">Rechazar solicitud</h1>
            <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
        </div>

        @if (solicitud is not null)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <div><strong>Solicitud:</strong> @solicitud.Id</div>
                    <div><strong>Cliente:</strong> @solicitud.Cliente?.Usuario?.UserName</div>
                    <div><strong>Monto:</strong> @solicitud.MontoSolicitado.ToString("C")</div>
                    <div><strong>Fecha:</strong> @solicitud.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                </div>
            </div>
        }

        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Rechazar" method="post" class="row g-3">
                    <input asp-for="SolicitudId" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="col-12">
                        <label asp-for="MotivoRechazo" class="form-label"></label>
                        <textarea asp-for="MotivoRechazo" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="MotivoRechazo" class="text-danger"></span>
                    </div>
                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Confirmar rechazo</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}