@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav align-items-lg-center gap-lg-2">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link app-nav-link app-user-pill" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">@UserManager.GetUserName(User)</a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn btn-link app-nav-link border-0 p-0">Cerrar sesion</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link app-nav-link" asp-area="Identity" asp-page="/Account/Register">Registrarse</a>
    </li>
    <li class="nav-item">
        <a class="btn btn-sm btn-dark rounded-pill px-3" asp-area="Identity" asp-page="/Account/Login">Iniciar sesion</a>
    </li>
}
</ul>
