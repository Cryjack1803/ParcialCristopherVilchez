@model SolicitudRegistroViewModel

@{
    ViewData["Title"] = "Registrar solicitud";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">Registrar solicitud</h1>
            <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
        </div>

        @if (ViewBag.SuccessMessage is string successMessage)
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert alert-danger"></div>
        }

        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post" class="row g-3">
                    <div class="col-12">
                        <label asp-for="MontoSolicitado" class="form-label"></label>
                        <input asp-for="MontoSolicitado" class="form-control" type="number" step="0.01" min="0.01" />
                        <span asp-validation-for="MontoSolicitado" class="text-danger"></span>
                    </div>
                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-success">Registrar solicitud</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}