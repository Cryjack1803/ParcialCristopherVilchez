@model SolicitudFiltroViewModel

@{
    ViewData["Title"] = "Mis solicitudes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Mis solicitudes</h1>
</div>

<div class="card mb-4">
    <div class="card-header">Filtros</div>
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-3">
                <label asp-for="Estado" class="form-label"></label>
                <select asp-for="Estado" class="form-select" asp-items="Html.GetEnumSelectList<EstadoSolicitud>()">
                    <option value="">Todos</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="MontoMinimo" class="form-label"></label>
                <input asp-for="MontoMinimo" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="MontoMinimo" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="MontoMaximo" class="form-label"></label>
                <input asp-for="MontoMaximo" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="MontoMaximo" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="FechaInicio" class="form-label"></label>
                <input asp-for="FechaInicio" class="form-control" type="date" />
                <span asp-validation-for="FechaInicio" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="FechaFin" class="form-label"></label>
                <input asp-for="FechaFin" class="form-control" type="date" />
                <span asp-validation-for="FechaFin" class="text-danger"></span>
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary">Filtrar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
            </div>
        </form>
    </div>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div asp-validation-summary="All" class="alert alert-danger"></div>
}

@if (Model.Solicitudes.Count == 0)
{
    <div class="alert alert-info">No se encontraron solicitudes para los filtros aplicados.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Monto</th>
                    <th>Fecha</th>
                    <th>Estado</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var solicitud in Model.Solicitudes)
            {
                <tr>
                    <td>@solicitud.Id</td>
                    <td>@solicitud.MontoSolicitado.ToString("C")</td>
                    <td>@solicitud.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@solicitud.Estado</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@solicitud.Id" class="btn btn-sm btn-outline-primary">Detalle</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}