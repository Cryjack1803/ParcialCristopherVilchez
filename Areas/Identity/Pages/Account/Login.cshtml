@page
@model ParcialVilchezCristopher_.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Iniciar sesion";
}

<div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
        <h1 class="h3 mb-3">Iniciar sesion</h1>
        <p class="text-muted">Puedes ingresar con tu correo o con tu nombre de usuario.</p>

        <div class="card shadow-sm">
            <div class="card-body">
                <form id="account" method="post" class="row g-3">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="col-12">
                        <label asp-for="Input.Identifier" class="form-label"></label>
                        <input asp-for="Input.Identifier" class="form-control" autocomplete="username" />
                        <span asp-validation-for="Input.Identifier" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Input.Password" class="form-label"></label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="col-12 form-check">
                        <input asp-for="Input.RememberMe" class="form-check-input" />
                        <label asp-for="Input.RememberMe" class="form-check-label"></label>
                    </div>

                    <div class="col-12 d-flex gap-2 flex-wrap">
                        <button id="login-submit" type="submit" class="btn btn-primary">Ingresar</button>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-outline-secondary">Crear cuenta</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}